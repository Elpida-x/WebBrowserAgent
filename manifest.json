{
  "manifest_version": 3,
  "name": "Web Browser Agent",
  "version": "0.1.0",
  "description": "An autonomous web-browsing assistant. Give it a task in natural language; it perceives the page, plans, and acts.",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "search"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Web Browser Agent"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
